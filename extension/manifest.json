{
  "manifest_version": 3,
  "name": "AJS Tab Helper",
  "version": "1.1",
  "description": "Lets Anki Japanese Sensei find your open YouTube tabs.",
  "permissions": ["tabs", "alarms"],
  "host_permissions": ["http://localhost:27384/*"],
  "commands": {
    "trigger-ajs": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Launch Anki Japanese Sensei for the current tab"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "AJS Tab Helper"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ajs-tab-helper@example.com",
      "strict_min_version": "109.0"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/watch*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
