{
  "manifest_version": 3,
  "name": "AJS Tab Helper",
  "version": "1.0",
  "description": "Lets Anki Japanese Sensei find your open YouTube tabs.",
  "permissions": ["tabs", "alarms"],
  "host_permissions": ["http://localhost:27384/*"],
  "background": {
    "service_worker": "background.js"
  },
"action": {
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "AJS Tab Helper"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
