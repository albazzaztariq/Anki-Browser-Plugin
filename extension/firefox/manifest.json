{
  "manifest_version": 2,
  "name": "AJS Tab Helper",
  "version": "1.1",
  "description": "Lets Anki Japanese Sensei find your open YouTube tabs.",
  "permissions": ["tabs", "alarms", "http://localhost:27384/*", "*://www.youtube.com/*"],
  "commands": {
    "trigger-ajs": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Launch Anki Japanese Sensei for the current tab"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "browser_action": {
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "AJS Tab Helper"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ajs-tab-helper@example.com"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
