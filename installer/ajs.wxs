<?xml version="1.0" encoding="UTF-8"?>
<!--
  AJS Windows Installer
  Extracts AJS_Setup.exe and runs it; AJS_Setup.exe handles the full install.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package Name="Anki Japanese Sensei"
           Manufacturer="AJS Project"
           Version="1.0.0"
           UpgradeCode="A3F7C2D1-884E-4B6A-9C3F-12E8D5A70B4C"
           Compressed="yes"
           InstallerVersion="500">

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of Anki Japanese Sensei is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="STAGINGROOT" Name="AJS_Install" />
    </StandardDirectory>

    <ComponentGroup Id="SetupFiles" Directory="STAGINGROOT">

      <Component Id="AJSSetupExe" Guid="B1D4E6F8-23A5-4C7D-9E0F-1A2B3C4D5E6F">
        <File Id="FILE_AJSSetupExe"
              Source="dist\AJS_Setup.exe"
              KeyPath="yes" />
      </Component>

      <Component Id="UninstallScript" Guid="C2E5F7A9-34B6-5D8E-AF10-2B3C4D5E6F7A">
        <File Id="FILE_Uninstall"
              Source="uninstall.bat"
              KeyPath="yes" />
        <RemoveFolder Id="STAGINGROOT_Remove" On="uninstall" />
      </Component>

    </ComponentGroup>

    <Feature Id="Complete" Title="Anki Japanese Sensei" Level="1">
      <ComponentGroupRef Id="SetupFiles" />
    </Feature>

    <CustomAction Id="CA_RunAJSSetup"
                  FileRef="FILE_AJSSetupExe"
                  ExeCommand=""
                  Execute="deferred"
                  Impersonate="yes"
                  Return="check" />

    <CustomAction Id="CA_Uninstall"
                  FileRef="FILE_Uninstall"
                  ExeCommand=""
                  Execute="deferred"
                  Impersonate="yes"
                  Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="CA_RunAJSSetup" After="InstallFiles" Condition="NOT Installed AND NOT REMOVE" />
      <Custom Action="CA_Uninstall" Before="RemoveFiles" Condition="REMOVE~=&quot;ALL&quot;" />
    </InstallExecuteSequence>

  </Package>
</Wix>
